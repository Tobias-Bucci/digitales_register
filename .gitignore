# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Visual Studio Code related
.vscode/

# Eclipse/Buildship settings inside local packages
packages/uni_links/**/**/.settings/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
**/.gradle/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/build/native_assets/
/build/test_cache/
/build/unit_test_assets/
/android/build/

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Exceptions to above rules.
!/packages/flutter_tools/test/data/dart_dependencies_test/**/.packages


# Generated files
**.g.dart

# Temporary test files
**/test/linux
/test/**/failures/
/flutter_*.log

# Private requests & answers
**/lib/requests/

# Android signing secrets
android/key.properties
android/*.jks
ios/Flutter/ephemeral/
macos/Flutter/GeneratedPluginRegistrant.swift

# ======= IOS =======
# Pods und Symlinks MÜSSEN ignoriert werden. Die werden auf dem Mac via "pod install" neu erzeugt!
**/ios/Pods/
**/ios/.symlinks/

# Generierte Konfigurationen für iOS, baut Flutter auf dem Mac automatisch neu
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh

# User-spezifische Xcode Cache-Dateien (verhindert Git-Merge-Konflikte)
*.mode1v3
*.mode2v3
*.pbxuser
*.perspectivev3
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
